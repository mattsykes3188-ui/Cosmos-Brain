{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Taxonomia Semantica",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "id",
      "label",
      "descricao",
      "categoria",
      "sinonimos",
      "exemplos",
      "relacionados",
      "status"
    ],
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
      },
      "label": {
        "type": "string",
        "minLength": 1
      },
      "descricao": {
        "type": "string",
        "minLength": 1
      },
      "categoria": {
        "type": "string",
        "minLength": 1
      },
      "sinonimos": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "exemplos": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "relacionados": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "status": {
        "enum": [
          "active",
          "draft",
          "deprecated"
        ]
      }
    }
  }
}
